{
    "require": {
        "doctrine/dbal": "^3.10",
        "doctrine/orm": "^2.20",
        "theodo-group/llphant": "*",
        "symfony/cache": "^7.0",
        "symfony/var-exporter": "^7.0",
        "symfony/console": "^8.0",
        "monolog/monolog": "^3.10"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse --memory-limit=256M",
        "phpunit": "phpunit --no-coverage",
        "test": [
            "@phpcs",
            "@phpstan",
            "@phpunit"
        ]
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
